{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for JANUS metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "JANUS Forward Service — Regime Detection, Bridge, and gRPC Server Monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Regime State Overview",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Hypothalamus Regime",
      "description": "Current hypothalamus regime classification for position sizing",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_bridge_hypothalamus_regime{asset=~\"$asset\"}",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Unknown", "color": "text", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "StrongBullish", "color": "dark-green", "index": 1 } } },
            { "type": "value", "options": { "2": { "text": "Bullish", "color": "green", "index": 2 } } },
            { "type": "value", "options": { "3": { "text": "Neutral", "color": "yellow", "index": 3 } } },
            { "type": "value", "options": { "4": { "text": "Bearish", "color": "orange", "index": 4 } } },
            { "type": "value", "options": { "5": { "text": "StrongBearish", "color": "red", "index": 5 } } },
            { "type": "value", "options": { "6": { "text": "HighVolatility", "color": "dark-red", "index": 6 } } },
            { "type": "value", "options": { "7": { "text": "LowVolatility", "color": "blue", "index": 7 } } },
            { "type": "value", "options": { "8": { "text": "Transitional", "color": "purple", "index": 8 } } },
            { "type": "value", "options": { "9": { "text": "Crisis", "color": "dark-red", "index": 9 } } },
            { "type": "value", "options": { "10": { "text": "Unknown", "color": "text", "index": 10 } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Amygdala Regime",
      "description": "Current amygdala regime classification for threat detection",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_bridge_amygdala_regime{asset=~\"$asset\"}",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Unknown", "color": "text", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "LowVolTrending", "color": "green", "index": 1 } } },
            { "type": "value", "options": { "2": { "text": "LowVolMeanRev", "color": "blue", "index": 2 } } },
            { "type": "value", "options": { "3": { "text": "HighVolTrending", "color": "orange", "index": 3 } } },
            { "type": "value", "options": { "4": { "text": "HighVolMeanRev", "color": "yellow", "index": 4 } } },
            { "type": "value", "options": { "5": { "text": "Crisis", "color": "dark-red", "index": 5 } } },
            { "type": "value", "options": { "6": { "text": "Transitional", "color": "purple", "index": 6 } } },
            { "type": "value", "options": { "7": { "text": "Unknown", "color": "text", "index": 7 } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "janus-regime Raw Regime",
      "description": "Underlying janus-regime detector classification (0=Uncertain, 1=TrendingBull, 2=TrendingBear, 3=MeanReverting, 4=Volatile)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_regime_current{asset=~\"$asset\"}",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Uncertain", "color": "text", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "Trending (Bull)", "color": "green", "index": 1 } } },
            { "type": "value", "options": { "2": { "text": "Trending (Bear)", "color": "red", "index": 2 } } },
            { "type": "value", "options": { "3": { "text": "MeanReverting", "color": "blue", "index": 3 } } },
            { "type": "value", "options": { "4": { "text": "Volatile", "color": "orange", "index": 4 } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Detector Ready",
      "description": "Whether the ensemble regime detector has warmed up (1 = ready)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_regime_detector_ready{asset=~\"$asset\"}",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Warming Up", "color": "yellow", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "Ready", "color": "green", "index": 1 } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Active Strategy",
      "description": "Currently recommended strategy (0=NoTrade, 1=TrendFollowing, 2=MeanReversion)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_regime_strategy_current{asset=~\"$asset\"}",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No Trade", "color": "text", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "TrendFollowing", "color": "green", "index": 1 } } },
            { "type": "value", "options": { "2": { "text": "MeanReversion", "color": "blue", "index": 2 } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "title": "Position Sizing & Risk",
      "type": "row"
    },
    {
      "id": 6,
      "title": "Position Scale",
      "description": "Position scale factor from bridged hypothalamus regime (0.0 = no position, 1.5 = max scale)",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_bridge_position_scale{asset=~\"$asset\"}",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1.5,
          "decimals": 2,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.3, "color": "orange" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.8, "color": "green" },
              { "value": 1.2, "color": "dark-green" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Position Factor (Router)",
      "description": "Position size factor recommended by the regime router",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_regime_position_factor{asset=~\"$asset\"}",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1.5,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.3, "color": "orange" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.8, "color": "green" },
              { "value": 1.0, "color": "dark-green" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Detection Confidence",
      "description": "Regime detection confidence (0.0-1.0). Higher = more certain of the regime classification.",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_regime_confidence{asset=~\"$asset\"}",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "decimals": 2,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.3, "color": "orange" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.7, "color": "green" },
              { "value": 0.85, "color": "dark-green" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Methods Agree",
      "description": "Whether indicator-based and HMM detectors agree on the regime (1 = agree, 0 = disagree)",
      "type": "stat",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_regime_methods_agree{asset=~\"$asset\"}",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Disagree", "color": "orange", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "Agree", "color": "green", "index": 1 } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Volume & Confidence Time Series",
      "type": "row"
    },
    {
      "id": 10,
      "title": "Relative Volume",
      "description": "Current candle volume relative to the rolling average (1.0 = average, >1.5 = elevated, >2.5 = spike)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_regime_relative_volume{asset=~\"$asset\"}",
          "legendFormat": "{{asset}} rel_vol",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 4,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "dashed" }
          },
          "min": 0,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 1.5, "color": "yellow" },
              { "value": 2.5, "color": "orange" },
              { "value": 5.0, "color": "red" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "Confidence & Agreement Over Time",
      "description": "Detection confidence and method agreement plotted together. Confidence dips during regime transitions are normal.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_regime_confidence{asset=~\"$asset\"}",
          "legendFormat": "{{asset}} confidence",
          "refId": "A"
        },
        {
          "expr": "janus_regime_methods_agree{asset=~\"$asset\"}",
          "legendFormat": "{{asset}} methods_agree",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": true,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.7, "color": "green" }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*methods_agree.*" },
            "properties": [
              { "id": "custom.drawStyle", "value": "bars" },
              { "id": "custom.fillOpacity", "value": 30 },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "semi-dark-purple" } }
            ]
          }
        ]
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Regime & Position Time Series",
      "type": "row"
    },
    {
      "id": 12,
      "title": "Hypothalamus Regime Over Time",
      "description": "Hypothalamus regime classification plotted over time (state graph)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_bridge_hypothalamus_regime{asset=~\"$asset\"}",
          "legendFormat": "{{asset}} hypo",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto"
          },
          "min": 0,
          "max": 10,
          "decimals": 0,
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Unknown" } } },
            { "type": "value", "options": { "1": { "text": "StrongBull" } } },
            { "type": "value", "options": { "2": { "text": "Bullish" } } },
            { "type": "value", "options": { "3": { "text": "Neutral" } } },
            { "type": "value", "options": { "4": { "text": "Bearish" } } },
            { "type": "value", "options": { "5": { "text": "StrongBear" } } },
            { "type": "value", "options": { "6": { "text": "HighVol" } } },
            { "type": "value", "options": { "7": { "text": "LowVol" } } },
            { "type": "value", "options": { "8": { "text": "Trans" } } },
            { "type": "value", "options": { "9": { "text": "Crisis" } } },
            { "type": "value", "options": { "10": { "text": "Unknown" } } }
          ],
          "color": { "mode": "continuous-BlYlRd" }
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "title": "Amygdala Regime Over Time",
      "description": "Amygdala threat regime classification plotted over time (state graph)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_bridge_amygdala_regime{asset=~\"$asset\"}",
          "legendFormat": "{{asset}} amyg",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto"
          },
          "min": 0,
          "max": 7,
          "decimals": 0,
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Unknown" } } },
            { "type": "value", "options": { "1": { "text": "LowVolTrend" } } },
            { "type": "value", "options": { "2": { "text": "LowVolMR" } } },
            { "type": "value", "options": { "3": { "text": "HighVolTrend" } } },
            { "type": "value", "options": { "4": { "text": "HighVolMR" } } },
            { "type": "value", "options": { "5": { "text": "Crisis" } } },
            { "type": "value", "options": { "6": { "text": "Trans" } } },
            { "type": "value", "options": { "7": { "text": "Unknown" } } }
          ],
          "color": { "mode": "continuous-BlYlRd" }
        },
        "overrides": []
      }
    },
    {
      "id": 14,
      "title": "Position Scale Over Time",
      "description": "Bridge position scale and router position factor over time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "janus_bridge_position_scale{asset=~\"$asset\"}",
          "legendFormat": "{{asset}} bridge_scale",
          "refId": "A"
        },
        {
          "expr": "janus_regime_position_factor{asset=~\"$asset\"}",
          "legendFormat": "{{asset}} router_factor",
          "refId": "B"
        }
      ],
